  # ==========================================================================
  # TIER 3: COLUMN SCHEMA VALIDATION (Detect added/removed/renamed columns)
  # ==========================================================================

  - name: test_columns_recent_documents
    description: "Validate Recent Documents sheet column headers"
    function: excel.validate_columns
    parameter:
      dst: "{{ case_directory }}/Reports/*/Excel.xlsx"
      sheet: "Recent Documents"
      expected_columns: ["Path", "Date/Time", "Path ID", "Source File", "Tags"]
      column_row: 0
      allow_extra_columns: false
      allow_missing_columns: false
      ignore_order: false

  - name: test_columns_tagged_files
