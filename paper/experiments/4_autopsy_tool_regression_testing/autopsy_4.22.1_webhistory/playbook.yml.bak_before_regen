settings:
  idle: 2.0
  timeout: 600
  screenshot:
    format: "png"
    quality: 95
variables:
  autopsy_version: 4.22.1
  case_name: "TestCase"
  case_directory: r"C:\Users\adare\Documents\{{ case_name }}"
tests:
  # ==========================================================================
  # TIER 1: FILE EXISTENCE
  # ==========================================================================

  - name: test_report_file_exists
    description: "Verify the Excel report file was generated"
    function: standard.file_exists
    parameter:
      dst: "{{ case_directory }}/Reports/*/Excel.xlsx"

  # ==========================================================================
  # TIER 2: SHEET STRUCTURE VALIDATION (Detect new/removed sheets)
  # ==========================================================================

  - name: test_sheet_data_source_usage_exists
