from adarevm.action.mcp_experiment import MCPExperiment
from adare.types.playbook import Target, ClickAction, KeyboardAction, IdleAction
from pathlib import Path
from typing import Callable, Awaitable
from adarevm.testset.testset import Testset

import logging

log = logging.getLogger(__name__)


class TrashBinDeleteFile(MCPExperiment):
    description = 'Delete file and verify it appears in recycle bin using forensic analysis'

    def __init__(self, img_folder: Path, tessdata_folder: Path, testset: Testset,
                 log_func: Callable[[str], Awaitable[None]]):
        """
        Initialize the TrashBinDeleteFile experiment with MCP-based GUI automation.
        
        This experiment demonstrates:
        - File creation and deletion operations
        - GUI automation using modern MCP approach
        - Forensic validation of recycle bin contents
        - Timestamp validation with tolerance
        """
        super().__init__(img_folder, tessdata_folder, testset, log_func)

    async def prepare(self) -> tuple[bool, str]:
        """
        Prepare the experiment by creating the test file.
        
        Creates a test file at C:/Users/vagrant/Documents/testfile
        that will be deleted during the experiment.
        """
        await self.log_func("Preparing experiment: creating test file")
        
        try:
            # Create test file
            test_file_path = Path('C:/Users/vagrant/Documents/testfile')
            test_file_path.parent.mkdir(parents=True, exist_ok=True)
            
            with open(test_file_path, 'w', encoding='utf-8') as f:
                from datetime import datetime
                timestamp = datetime.now().isoformat()
                f.write('This is a test file for ADARE TrashBinDeleteFile experiment.\n')
                f.write('Created for testing file deletion and recycle bin validation.\n')
                f.write(f'Timestamp: {timestamp}\n')
            
            await self.log_func(f"Test file created successfully: {test_file_path}")
            return True, "Test file created successfully"
            
        except Exception as e:
            error_msg = f"Failed to create test file: {e}"
            await self.log_func(error_msg)
            return False, error_msg

    async def run(self) -> tuple[bool, str]:
        """
        Execute the main experiment: navigate to file and delete it.
        
        Uses GUI automation to:
        1. Open File Explorer
        2. Navigate to Documents folder  
        3. Find and select the test file
        4. Delete the file using DELETE key
        5. Record deletion timestamp for forensic validation
        """
        await self.log_func(f"Starting experiment {self.name}")

        # Define the GUI automation sequence
        actions = [
            # Open File Explorer by clicking on Files icon
            ClickAction(
                target=Target(image="files.png"),
                description="Click File Explorer icon in taskbar"
            ),
            
            # Wait for File Explorer to open
            IdleAction(
                duration=2.0,
                description="Wait for File Explorer to load"
            ),
            
            # Navigate to Documents folder
            ClickAction(
                target=Target(image="documents.png"),
                description="Click Documents folder in sidebar"
            ),
            
            # Wait for Documents folder to load
            IdleAction(
                duration=2.0,
                description="Wait for Documents folder to load"
            ),
            
            # Click on the test file to select it
            ClickAction(
                target=Target(image="testfile.png"),
                description="Select the test file"
            ),
            
            # Wait to ensure file is selected
            IdleAction(
                duration=1.0,
                description="Wait for file selection"
            ),
            
            # Delete the file using DELETE key
            KeyboardAction(
                combination=["delete"],
                description="Delete the selected file"
            ),
        ]
        
        # Execute the actions
        result = await self.execute_actions(actions)
        
        if result[0]:  # If actions were successful
            # Save the deletion timestamp for forensic validation
            from datetime import datetime
            deletion_timestamp = datetime.now().isoformat()
            self.set_variable('TIMESTAMP.DELETIONDATE', deletion_timestamp)
            await self.log_func(f"File deletion completed, timestamp saved: {deletion_timestamp}")
            
            # Note: Test execution is handled by the framework automatically
            # The testset.yml will be executed by the experiment runner
            await self.log_func("GUI automation completed successfully")
            await self.log_func(f"Experiment {self.name} completed successfully")
            return True, "Experiment completed successfully"
        else:
            await self.log_func(f"GUI automation failed: {result[1]}")
            return False, f"GUI automation failed: {result[1]}"

    async def cleanup(self) -> tuple[bool, str]:
        """
        Clean up after experiment execution.
        
        This experiment doesn't require explicit cleanup as:
        - The test file has been deleted (which was the goal)
        - File Explorer will be closed by the VM reset
        - Forensic tools output is preserved for analysis
        """
        await self.log_func("Cleaning up experiment")
        
        # Close File Explorer if still open (optional)
        try:
            # Press Alt+F4 to close current window
            await self.press_keys(["alt", "f4"], "Close File Explorer")
            await self.wait(1.0, "Wait for window to close")
        except Exception as e:
            # Not critical if this fails
            await self.log_func(f"Note: Could not close File Explorer: {e}")
        
        await self.log_func("Cleanup completed")
        return True, "Cleanup completed successfully"


