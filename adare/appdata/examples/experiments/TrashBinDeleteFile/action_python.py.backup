"""
settings:
  idle: 1.0

actions:
  - click:
      target:
        image: "files.png"
      description: "Open File Explorer"
  
  - idle:
      duration: 2.0
      description: "Wait for File Explorer to load"
  
  - click:
      target:
        image: "documents.png"
      description: "Navigate to Documents folder"
  
  - idle:
      duration: 2.0
      description: "Wait for Documents folder to load"
  
  - click:
      target:
        image: "testfile.png"
      description: "Select the test file"
  
  - idle:
      duration: 1.0
      description: "Wait for file selection"
  
  - keyboard:
      combination: ["delete"]
      description: "Delete the selected file"
  
  # Optional: Handle confirmation dialog if it appears
  - block:
      description: "Handle delete confirmation if shown"
      when:
        - exists:
            text: "Are you sure"
      actions:
        - click:
            target:
              text: "Yes"
            description: "Confirm deletion"
"""