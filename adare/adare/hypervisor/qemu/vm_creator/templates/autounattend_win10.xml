<?xml version="1.0" encoding="utf-8"?>
<unattend xmlns="urn:schemas-microsoft-com:unattend" xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">

  <!-- Windows PE pass - disk partitioning and driver injection -->
  <settings pass="windowsPE">
    <component name="Microsoft-Windows-International-Core-WinPE"
               processorArchitecture="{{ proc_arch }}"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      <SetupUILanguage>
        <UILanguage>en-US</UILanguage>
      </SetupUILanguage>
      <InputLocale>en-US</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>

    <component name="Microsoft-Windows-Setup"
               processorArchitecture="{{ proc_arch }}"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">

      <!-- Bypass CPU check for QEMU's emulated CPU -->
      <RunSynchronous>
        <RunSynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Path>reg add HKLM\SYSTEM\Setup\LabConfig /v BypassCPUCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
      </RunSynchronous>

      <DiskConfiguration>
        <Disk wcm:action="add">
          <DiskID>0</DiskID>
          <WillWipeDisk>true</WillWipeDisk>
          <CreatePartitions>
            <!-- EFI System Partition -->
            <CreatePartition wcm:action="add">
              <Order>1</Order>
              <Size>260</Size>
              <Type>EFI</Type>
            </CreatePartition>
            <!-- Microsoft Reserved -->
            <CreatePartition wcm:action="add">
              <Order>2</Order>
              <Size>16</Size>
              <Type>MSR</Type>
            </CreatePartition>
            <!-- Windows partition (rest of disk) -->
            <CreatePartition wcm:action="add">
              <Order>3</Order>
              <Extend>true</Extend>
              <Type>Primary</Type>
            </CreatePartition>
          </CreatePartitions>
          <ModifyPartitions>
            <ModifyPartition wcm:action="add">
              <Order>1</Order>
              <PartitionID>1</PartitionID>
              <Format>FAT32</Format>
              <Label>EFI</Label>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>2</Order>
              <PartitionID>3</PartitionID>
              <Format>NTFS</Format>
              <Label>Windows</Label>
              <Letter>C</Letter>
            </ModifyPartition>
          </ModifyPartitions>
        </Disk>
      </DiskConfiguration>

      <ImageInstall>
        <OSImage>
          <InstallTo>
            <DiskID>0</DiskID>
            <PartitionID>3</PartitionID>
          </InstallTo>
        </OSImage>
      </ImageInstall>

      <UserData>
        <AcceptEula>true</AcceptEula>
        {% if proc_arch == 'arm64' %}
        <ProductKey>
          <Key>W269N-WFGWX-YVC9B-4J6C9-T83GX</Key>
          <WillShowUI>OnError</WillShowUI>
        </ProductKey>
        {% endif %}
      </UserData>
    </component>

    {% if proc_arch != 'arm64' %}
    <component name="Microsoft-Windows-PnPCustomizationsWinPE"
               processorArchitecture="{{ proc_arch }}"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      <DriverPaths>
        <!-- viostor (critical) - D through J -->
        <PathAndCredentials wcm:action="add" wcm:keyValue="1">
          <Path>D:\viostor\w10\{{ driver_arch }}</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="2">
          <Path>E:\viostor\w10\{{ driver_arch }}</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="3">
          <Path>F:\viostor\w10\{{ driver_arch }}</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="4">
          <Path>G:\viostor\w10\{{ driver_arch }}</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="5">
          <Path>H:\viostor\w10\{{ driver_arch }}</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="6">
          <Path>I:\viostor\w10\{{ driver_arch }}</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="7">
          <Path>J:\viostor\w10\{{ driver_arch }}</Path>
        </PathAndCredentials>
        <!-- NetKVM - D through J -->
        <PathAndCredentials wcm:action="add" wcm:keyValue="8">
          <Path>D:\NetKVM\w10\{{ driver_arch }}</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="9">
          <Path>E:\NetKVM\w10\{{ driver_arch }}</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="10">
          <Path>F:\NetKVM\w10\{{ driver_arch }}</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="11">
          <Path>G:\NetKVM\w10\{{ driver_arch }}</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="12">
          <Path>H:\NetKVM\w10\{{ driver_arch }}</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="13">
          <Path>I:\NetKVM\w10\{{ driver_arch }}</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="14">
          <Path>J:\NetKVM\w10\{{ driver_arch }}</Path>
        </PathAndCredentials>
        <!-- viogpudo intentionally excluded from WinPE DriverPaths.
             Loading the GPU driver during WinPE causes black screen issues
             (display driver switch from ramfb to virtio-gpu-pci crashes WinPE).
             The driver gets installed later via virtio-win guest tools in FirstLogonCommands.
             Matches UTM's proven approach: https://github.com/utmapp/spice-nsis/blob/main/Autounattend.xml -->
      </DriverPaths>
    </component>
    {% endif %}
  </settings>

  <!-- OOBE pass - user account and regional settings -->
  <settings pass="oobeSystem">
    <component name="Microsoft-Windows-International-Core"
               processorArchitecture="{{ proc_arch }}"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      <InputLocale>en-US</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>

    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="{{ proc_arch }}"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideLocalAccountScreen>true</HideLocalAccountScreen>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <ProtectYourPC>3</ProtectYourPC>
        <VMModeOptimizations>
          <SkipWinREInitialization>true</SkipWinREInitialization>
        </VMModeOptimizations>
      </OOBE>

      <UserAccounts>
        <LocalAccounts>
          <LocalAccount wcm:action="add">
            <Name>adare</Name>
            <Group>Administrators</Group>
            <Password>
              <Value>adare</Value>
              <PlainText>true</PlainText>
            </Password>
          </LocalAccount>
        </LocalAccounts>
      </UserAccounts>

      <AutoLogon>
        <Enabled>true</Enabled>
        <Username>adare</Username>
        <Password>
          <Value>adare</Value>
          <PlainText>true</PlainText>
        </Password>
        <LogonCount>999</LogonCount>
      </AutoLogon>

      <!-- First logon commands - post-install configuration -->
      <FirstLogonCommands>
        <!-- Disable UAC -->
        <SynchronousCommand wcm:action="add">
          <Order>1</Order>
          <CommandLine>reg add "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\System" /v EnableLUA /t REG_DWORD /d 0 /f</CommandLine>
          <Description>Disable UAC</Description>
        </SynchronousCommand>
        <!-- Disable Windows Update -->
        <SynchronousCommand wcm:action="add">
          <Order>2</Order>
          <CommandLine>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\WindowsUpdate\AU" /v NoAutoUpdate /t REG_DWORD /d 1 /f</CommandLine>
          <Description>Disable Windows Update</Description>
        </SynchronousCommand>
        <!-- Disable sleep/hibernate -->
        <SynchronousCommand wcm:action="add">
          <Order>3</Order>
          <CommandLine>powercfg /change standby-timeout-ac 0</CommandLine>
          <Description>Disable sleep</Description>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <Order>4</Order>
          <CommandLine>powercfg /change monitor-timeout-ac 0</CommandLine>
          <Description>Disable monitor timeout</Description>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <Order>5</Order>
          <CommandLine>powercfg /hibernate off</CommandLine>
          <Description>Disable hibernate</Description>
        </SynchronousCommand>
        {% if setup_level >= 1 %}
        <!-- Open firewall port 18765 for ADARE guest agent -->
        <SynchronousCommand wcm:action="add">
          <Order>6</Order>
          <CommandLine>netsh advfirewall firewall add rule name="ADARE Guest Agent" dir=in action=allow protocol=tcp localport=18765</CommandLine>
          <Description>Open ADARE port</Description>
        </SynchronousCommand>
        <!-- Install virtio guest agent from secondary CD -->
        <SynchronousCommand wcm:action="add">
          <Order>7</Order>
          <CommandLine>cmd /c for %d in (D E F) do if exist %d:\virtio-win-guest-tools.exe %d:\virtio-win-guest-tools.exe /S</CommandLine>
          <Description>Install virtio guest tools</Description>
        </SynchronousCommand>
        {% endif %}
        {% if setup_level >= 2 %}
        <!-- Download Miniforge3 -->
        <SynchronousCommand wcm:action="add">
          <Order>8</Order>
          <CommandLine>curl.exe -L -o C:\Users\adare\miniforge3-installer.exe https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Windows-{{ miniforge_arch }}.exe</CommandLine>
          <Description>Download Miniforge3</Description>
        </SynchronousCommand>
        <!-- Install Miniforge3 silently -->
        <SynchronousCommand wcm:action="add">
          <Order>9</Order>
          <CommandLine>C:\Users\adare\miniforge3-installer.exe /InstallationType=JustMe /RegisterPython=0 /S /D=C:\Users\adare\.miniforge3</CommandLine>
          <Description>Install Miniforge3</Description>
        </SynchronousCommand>
        <!-- Create pyadare conda environment -->
        <SynchronousCommand wcm:action="add">
          <Order>10</Order>
          <CommandLine>C:\Users\adare\.miniforge3\condabin\conda.bat create -n pyadare python=3.10 -y</CommandLine>
          <Description>Create pyadare conda environment</Description>
        </SynchronousCommand>
        <!-- Clean up installer -->
        <SynchronousCommand wcm:action="add">
          <Order>11</Order>
          <CommandLine>del C:\Users\adare\miniforge3-installer.exe</CommandLine>
          <Description>Clean up Miniforge3 installer</Description>
        </SynchronousCommand>
        {% endif %}
        <!-- Shutdown after setup complete -->
        <SynchronousCommand wcm:action="add">
          <Order>{% if setup_level >= 2 %}12{% elif setup_level >= 1 %}8{% else %}6{% endif %}</Order>
          <CommandLine>shutdown /s /t 60 /c "ADARE: Initial setup complete"</CommandLine>
          <Description>Shutdown after setup</Description>
        </SynchronousCommand>
      </FirstLogonCommands>
    </component>
  </settings>

</unattend>
